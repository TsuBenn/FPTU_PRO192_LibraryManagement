package controllers;

import java.time.LocalDate;
import java.util.ArrayList;
import java.util.List;
import managers.BookManager;
import managers.MemberManager;
import managers.BorrowTransactionManager;
import models.Book;
import models.Member;
import models.BorrowTransaction;
import utilities.Input;
import utilities.UIRender;
import utilities.Validator;
import utilities.IDManager;

public class LibraryController {
    private BookManager bookManager;
    private MemberManager memberManager;
    private BorrowTransactionManager txManager;

    public LibraryController() {
        this.bookManager = new BookManager();
        this.memberManager = new MemberManager();
        this.txManager = new BorrowTransactionManager(bookManager, memberManager);
        seedData();
    }

    public void start() {
        boolean running = true;
        String[] mainOptions = {
            "Book Management",
            "Member Management",
            "Borrow a Book",
            "Return a Book"
        };

        while (running) {
            UIRender.clearScreen();
            UIRender.renderMenu("Library Main Menu", mainOptions);

            int choice = Input.getInt("Select an option: ");
            switch (choice) {
                case 1: handleBookMenu(); break;
                case 2: handleMemberMenu(); break;
                case 3: handleBorrowWorkflow(); break;
                case 4: handleReturnWorkflow(); break;
                case 0: running = false; break;
                default: 
                UIRender.renderError("Invalid option!");
                UIRender.pauseEnter();
            }
        }
    }

    private void handleBookMenu() {
        boolean inMenu = true;
        String[] bookOptions = { "Add Book", "View All Books" };

        while (inMenu) {
            UIRender.clearScreen();
            UIRender.renderMenu("Book Management", bookOptions);
            int choice = Input.getInt("Select: ");

            if (choice == 1) {
                UIRender.clearScreen();
                UIRender.renderHeader("Add New Book");
                String id = IDManager.generateBookID();
                System.out.println("Generated Book ID: " + id);

                String title = Input.getString("Enter Title: ");
                String author = Input.getString("Enter Author: ");
                String genre = Input.getString("Enter Genre: ");
                int year = Input.getInt("Enter Publication Year: ");
                int qty = Input.getInt("Enter Total Quantity: ");

                Book book = new Book(id, title, author, genre, year, qty);
                if (bookManager.addBook(book)) {
                    UIRender.renderSuccess("Book added successfully!");
                } else {
                    UIRender.renderError("Failed to add book.");
                }
                UIRender.pauseEnter();
            } else if (choice == 2) {
                UIRender.clearScreen();
                UIRender.renderHeader("Book Database Registry");

                List<Book> books = bookManager.getAllBooks();
                String[] headers = {"ID", "Title", "Author", "Genre", "Year", "Available", "Total"};
                List<String[]> tableData = new ArrayList<>();

                for (Book b : books) {
                    tableData.add(new String[] {
                        b.getId(), b.getTitle(), b.getAuthor(), b.getGenre(),
                        String.valueOf(b.getPublicationYear()),
                        String.valueOf(b.getAvailableQuantity()),
                        String.valueOf(b.getTotalQuantity())
                    });
                }

                UIRender.renderTable(headers, tableData);
                UIRender.pauseEnter();
            } else if (choice == 0) {
                inMenu = false;
            } else {
                UIRender.renderError("Invalid Option!");
                UIRender.pauseEnter();
            }
        }
    }

    private void handleMemberMenu() {
        boolean inMenu = true;
        String[] memberOptions = { "Register Member", "View All Members" };

        while (inMenu) {
            UIRender.clearScreen();
            UIRender.renderMenu("Member Management", memberOptions);
            int choice = Input.getInt("Select: ");

            if (choice == 1) {
                UIRender.clearScreen();
                UIRender.renderHeader("Register New Member");
                String id = IDManager.generateMemberID();
                System.out.println("Generated Member ID: " + id);

                String name = Input.getString("Enter Name: ");
                String phone = Input.getString("Enter Phone (10 digits): ");
                String email = Input.getString("Enter Email: ");

                if (!Validator.isValidPhone(phone) || !Validator.isValidEmail(email)) {
                    UIRender.renderError("Invalid contact details format!");
                    UIRender.pauseEnter();
                    continue;
                }

                Member m = new Member(id, name, phone, email);
                if (memberManager.addMember(m)) {
                    UIRender.renderSuccess("Member registered successfully!");
                } else {
                    UIRender.renderError("Failed to register member.");
                }
                UIRender.pauseEnter();
            } else if (choice == 2) {
                UIRender.clearScreen();
                UIRender.renderHeader("Member Database Registry");

                List<Member> members = memberManager.getAllMembers();
                String[] headers = {"ID", "Name", "Phone Number", "Email Address"};
                List<String[]> tableData = new ArrayList<>();

                for (Member m : members) {
                    tableData.add(new String[] { m.getId(), m.getName(), m.getPhone(), m.getEmail() });
                }

                UIRender.renderTable(headers, tableData);
                UIRender.pauseEnter();
            } else if (choice == 0) {
                inMenu = false;
            } else {
                UIRender.renderError("Invalid Option!");
                UIRender.pauseEnter();
            }
        }
    }

    private void handleBorrowWorkflow() {
        UIRender.clearScreen();
        UIRender.renderHeader("Borrow Workflow: Select Member");
        String mQuery = Input.getString("Enter Member Name or ID to search: ");
        List<Member> matchedMembers = memberManager.searchMembers(mQuery);

        if (matchedMembers.isEmpty()) {
            UIRender.renderError("No matching members found.");
            UIRender.pauseEnter();
            return;
        }

        String[] memberHeaders = {"Index", "ID", "Name"};
        List<String[]> memberTable = new ArrayList<>();
        for (int i = 0; i < matchedMembers.size(); i++) {
            Member m = matchedMembers.get(i);
            memberTable.add(new String[] { String.valueOf(i + 1), m.getId(), m.getName() });
        }
        UIRender.renderTable(memberHeaders, memberTable);

        int mIdx = Input.getInt("Select member index: ") - 1;
        if (mIdx < 0 || mIdx >= matchedMembers.size()) return;
        Member member = matchedMembers.get(mIdx);

        System.out.println("\n");
        UIRender.renderHeader("Borrow Workflow: Select Book");
        String bQuery = Input.getString("Enter Book Title, Author or ID to search: ");
        List<Book> matchedBooks = bookManager.searchBooks(bQuery);

        if (matchedBooks.isEmpty()) {
            UIRender.renderError("No matching books found.");
            UIRender.pauseEnter();
            return;
        }

        String[] bookHeaders = {"Index", "ID", "Title", "Author", "Available"};
        List<String[]> bookTable = new ArrayList<>();
        for (int i = 0; i < matchedBooks.size(); i++) {
            Book b = matchedBooks.get(i);
            bookTable.add(new String[] { String.valueOf(i + 1), b.getId(), b.getTitle(), b.getAuthor(), String.valueOf(b.getAvailableQuantity()) });
        }
        UIRender.renderTable(bookHeaders, bookTable);

        int bIdx = Input.getInt("Select book index: ") - 1;
        if (bIdx < 0 || bIdx >= matchedBooks.size()) return;
        Book book = matchedBooks.get(bIdx);

        System.out.println("\n");
        LocalDate borrowDate = Input.getDate("--- Borrow Workflow: Loan Date Processing ---");

        String generatedTxId = IDManager.generateTransactionID();
        boolean success = txManager.borrowBook(generatedTxId, member.getId(), book.getId(), borrowDate);
        if (success) {
            UIRender.renderSuccess("ID: " + generatedTxId + " | Book '" + book.getTitle() + "' successfully assigned to " + member.getName());
        } else {
            UIRender.renderError("Transaction Rejected! System validation constraints triggered.");
        }
        UIRender.pauseEnter();
    }

    private void handleReturnWorkflow() {
        UIRender.clearScreen();
        UIRender.renderHeader("Return Workflow: Select Member");

        // Step 1: Search and Select the Member
        String mQuery = Input.getString("Enter Member Name or ID to search: ");
        List<Member> matchedMembers = memberManager.searchMembers(mQuery);

        if (matchedMembers.isEmpty()) {
            UIRender.renderError("No matching members found.");
            UIRender.pauseEnter();
            return;
        }

        String[] memberHeaders = {"Index", "ID", "Name"};
        List<String[]> memberTable = new ArrayList<>();
        for (int i = 0; i < matchedMembers.size(); i++) {
            Member m = matchedMembers.get(i);
            memberTable.add(new String[] { String.valueOf(i + 1), m.getId(), m.getName() });
        }
        UIRender.renderTable(memberHeaders, memberTable);

        int mIdx = Input.getInt("Select member index: ") - 1;
        if (mIdx < 0 || mIdx >= matchedMembers.size()) return;
        Member member = matchedMembers.get(mIdx);

        // Step 2: Fetch and Display ONLY Active Loans for this Member
        System.out.println("\n");
        UIRender.renderHeader("Active Loans for " + member.getName());
        List<BorrowTransaction> activeLoans = txManager.getActiveTransactionsByMember(member.getId());

        if (activeLoans.isEmpty()) {
            UIRender.renderError("This member currently has no outstanding books checked out.");
            UIRender.pauseEnter();
            return;
        }

        String[] loanHeaders = {"Index", "Book ID", "Book Title", "Borrow Date", "Due Date"};
        List<String[]> loanTable = new ArrayList<>();
        for (int i = 0; i < activeLoans.size(); i++) {
            BorrowTransaction tx = activeLoans.get(i);
            // Cross-reference the Book ID with the BookManager to print the actual Title
            Book book = bookManager.findBookById(tx.getBookId());
            String title = (book != null) ? book.getTitle() : "Unknown Asset";

            loanTable.add(new String[] {
                String.valueOf(i + 1),
                tx.getBookId(),
                title,
                tx.getBorrowDate().toString(),
                tx.getDueDate().toString()
            });
        }
        UIRender.renderTable(loanHeaders, loanTable);

        int lIdx = Input.getInt("Select book index to return: ") - 1;
        if (lIdx < 0 || lIdx >= activeLoans.size()) return;
        BorrowTransaction targetTx = activeLoans.get(lIdx);

        // Step 3: Date Handling Logic (Your flexible days-kept shortcut configuration)
        System.out.println("\n");
        UIRender.renderHeader("Processing Return for: " + bookManager.findBookById(targetTx.getBookId()).getTitle());
        LocalDate borrowDate = targetTx.getBorrowDate();
        LocalDate returnDate = null;

        System.out.println("Return Tracking Configuration Options:");
        System.out.println("  [1] Enter a specific calendar date");
        System.out.println("  [2] Enter total days kept (Relative to borrow date)");
        int returnChoice = Input.getInt("Select option: ");

        if (returnChoice == 1) {
            System.out.println("\n");
            returnDate = Input.getDate("--- Enter Actual Return Date ---");
        } else if (returnChoice == 2) {
            System.out.println("\nAsset was checked out on: " + borrowDate);
            int daysKept = Input.getInt("Enter number of days the member kept the book: ");
            if (daysKept < 0) {
                UIRender.renderError("Days kept cannot be negative!");
                UIRender.pauseEnter();
                return;
            }
            returnDate = borrowDate.plusDays(daysKept);
        } else {
            UIRender.renderError("Invalid option selected!");
            UIRender.pauseEnter();
            return;
        }

        // Step 4: Chronological Safety Check
        if (returnDate.isBefore(borrowDate)) {
            UIRender.renderError("Chronological Error: Return date (" + returnDate + 
                ") cannot sit behind borrow date (" + borrowDate + ").");
            UIRender.pauseEnter();
            return;
        }

        // Step 5: Execute via safe concrete IDs pulled straight from our selection
        double fine = txManager.returnBook(member.getId(), targetTx.getBookId(), returnDate);
        if (fine > 0) {
            UIRender.renderSuccess("Item returned successfully!");
            System.out.printf(">>> LATE RETURN PENALTY FEE DUE: %,.0f VND\n", fine);
        } else {
            UIRender.renderSuccess("Item returned on schedule. Zero balance fines.");
        }
        UIRender.pauseEnter();
    }

    private void seedData() {
        bookManager.addBook(new Book(IDManager.generateBookID(), "The Great Gatsby", "F. Scott Fitzgerald", "Classic", 1925, 5));
        bookManager.addBook(new Book(IDManager.generateBookID(), "1984", "George Orwell", "Dystopian", 1949, 3));
        memberManager.addMember(new Member(IDManager.generateMemberID(), "Benn", "0123456789", "benn@uni.edu.vn"));
    }
}
